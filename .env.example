# Development server
NODE_ENV=development
FRONTEND_PORT=5173

# Offline mode (uses mock data, no Jira connection needed)
# Automatically set by `npm run dev:offline`
OFFLINE_MODE=false

# API proxy target (used by rspack devServer proxy for /api routes)
API_URL=http://localhost:3000

# CORS Proxy settings (for cors-proxy.js)
CORS_PROXY_HOST=localhost
CORS_PROXY_PORT=8081

# SOCKS5 proxy (for corporate networks)
# Automatically set by `npm run cors-proxy:socks`
# SOCKS_PROXY=socks5h://127.0.0.1:8080
